# ── BOT IDENTITY ────────────────────────────────────────────
BOT_NAME=Trailer-UPS BOT
OWNER_NUMBER=256706106326        # Your WhatsApp number (no + or spaces)

# ── PAIRING ─────────────────────────────────────────────────
PAIRING_METHOD=phone             # 'phone' for pairing code, 'qr' for QR scan
PAIRING_PHONE=256706106326       # Phone number for pairing code

# ── SESSION ─────────────────────────────────────────────────
SESSION_DIR=./auth_info_baileys

# ── FEATURES ────────────────────────────────────────────────
AUTO_STATUS_VIEW=true
AUTO_BIO=true
ANTI_DELETE=true
ANTI_EDIT=true
ANTI_DELETE_SEND_TO=owner        # 'owner' or 'same_chat'
ANTI_VIEW_ONCE=true
PREFIX=.

# ── AI (Optional) ───────────────────────────────────────────
AI_API_KEY=                      # Your OpenAI or compatible API key
AI_MODEL=gpt-3.5-turbo
AI_BASE_URL=https://api.openai.com/v1
AI_SYSTEM_PROMPT=You are a helpful WhatsApp assistant. Reply concisely.

# ── GITHUB (for .update command) ────────────────────────────
GITHUB_REPO=realjumason-md/Trailer-upsmd
GITHUB_BRANCH=main

# ── SERVER ──────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=silent
