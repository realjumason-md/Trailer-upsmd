# ─────────────────────────────────────────────────────────────────
#  TRAILER-UPS BOT — environment variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Bot identity ────────────────────────────────────────────────
BOT_NAME=Trailer-UPS BOT
OWNER_NUMBER=256706106326      # Your WhatsApp number (country code, no + or spaces)
PREFIX=.

# ── Session / pairing ───────────────────────────────────────────
# Option 1 — enter your phone number; the bot prints a pairing code on first start.
PAIRING_NUMBER=                # e.g. 256706106326 — leave blank to be prompted

# Option 2 — paste a base64 creds.json to skip pairing entirely.
SESSION_ID=

SESSION_DIR=./session

# ── Features ────────────────────────────────────────────────────
AUTO_STATUS_VIEW=true
AUTO_BIO=true
ANTI_DELETE=true
ANTI_EDIT=true
ANTI_VIEW_ONCE=true
ANTI_DELETE_SEND_TO=owner      # 'owner' or 'same_chat'

# ── AI — Groq free tier ─────────────────────────────────────────
# Get a free key at https://console.groq.com
AI_ENABLED=false
AI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
AI_MODEL=llama3-8b-8192
AI_BASE_URL=https://api.groq.com/openai/v1
# Other free Groq models: llama-3.1-8b-instant  |  llama3-70b-8192  |  gemma2-9b-it
AI_SYSTEM_PROMPT=You are a helpful WhatsApp assistant. Reply concisely.

# ── Shazam — RapidAPI ───────────────────────────────────────────
# Required for the .shazam command. Free tier available.
# Sign up at https://rapidapi.com and subscribe to "Shazam API 6" (free plan).
RAPIDAPI_KEY=

# ── GitHub (for .update command) ────────────────────────────────
GITHUB_REPO=realjumason-md/Trailer-upsmd
GITHUB_BRANCH=main

# ── Server ──────────────────────────────────────────────────────
PORT=5000

# ── Keep-alive (free-tier hosting like Render / Railway) ────────
# Set to your app's public URL to prevent free-tier sleep.
# The bot pings itself every 14 minutes (Render sleeps after 15).
# Example: https://your-app.onrender.com
KEEP_ALIVE_URL=
# Override ping interval in ms (default 14 minutes = 840000)
KEEP_ALIVE_INTERVAL=840000
