# ── BOT IDENTITY ────────────────────────────────────────────
BOT_NAME=Trailer-UPS BOT
OWNER_NUMBER=256706106326        # Your WhatsApp number (no + or spaces)

# ── PAIRING ─────────────────────────────────────────────────
PAIRING_METHOD=phone             # 'phone' for pairing code, 'qr' for QR scan
PAIRING_PHONE=                    # Optional; blank means prompt in the server console

# ── SESSION ─────────────────────────────────────────────────
SESSION_DIR=./auth_info_baileys

# ── FEATURES ────────────────────────────────────────────────
AUTO_STATUS_VIEW=true
AUTO_BIO=true
ANTI_DELETE=true
ANTI_EDIT=true
ANTI_DELETE_SEND_TO=owner        # 'owner' or 'same_chat'
ANTI_VIEW_ONCE=true
PREFIX=.

# ── AI — Groq free tier ─────────────────────────────────────
# Get your free key at: https://console.groq.com
AI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
AI_MODEL=llama3-8b-8192
AI_BASE_URL=https://api.groq.com/openai/v1
# Other free Groq models you can swap in:
#   llama-3.1-8b-instant   (faster)
#   llama3-70b-8192        (smarter, still free)
#   mixtral-8x7b-32768     (large context)
#   gemma2-9b-it
AI_SYSTEM_PROMPT=You are a helpful WhatsApp assistant. Reply concisely.

# ── GITHUB (for .update command) ────────────────────────────
GITHUB_REPO=realjumason-md/Trailer-upsmd
GITHUB_BRANCH=main

# ── SERVER ──────────────────────────────────────────────────
PORT=5000
LOG_LEVEL=silent
